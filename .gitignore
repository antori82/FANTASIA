# Build intermediates (auto-regenerated by UE build system)
FANTASIA/Intermediate/

# Debug symbols (large, not needed for plugin users)
*.pdb

# Whisper models — fetched by bootstrap.{bat,sh} from the runtime-v2.0
# release. Never tracked; they're huge and live in release assets.
FANTASIA/Resources/ggml-*.bin

# CUDA leftover DLLs — removed from HEAD; the static-CUDA build pipeline
# stages them automatically when a user runs build_whisper_cuda.bat
FANTASIA/Binaries/Win64/cudart64_*.dll
FANTASIA/Binaries/Win64/cublas64_*.dll
FANTASIA/Binaries/Win64/cublasLt64_*.dll
FANTASIA/Binaries/Win64/ggml-cuda.dll

# Win64 build-time static libs — fetched by bootstrap.{bat,sh} from the
# runtime-v2.0 release. ~330 MB uncompressed of aGrUM + gRPC + OpenSSL
# Win64 static libs needed at plugin compile time.
FANTASIA/ThirdParty/aGrUM/Libraries/agrum.x64.lib
FANTASIA/ThirdParty/grpc/lib/win64/Release/
FANTASIA/ThirdParty/OpenSSL/1.1.1t/lib/Win64/VS2015/Release/

# Microsoft Speech SDK — fetched by bootstrap from the runtime-v2.0 release.
# Used at build time + at runtime via vendor DLLs staged into Binaries/Win64.
FANTASIA/ThirdParty/Microsoft.CognitiveServices.Speech.1.32.1/

# whisper.cpp — only source, headers, and prebuilt libs are needed
FANTASIA/ThirdParty/whisper_cpp/build/
FANTASIA/ThirdParty/whisper_cpp/examples/
FANTASIA/ThirdParty/whisper_cpp/bindings/
FANTASIA/ThirdParty/whisper_cpp/tests/
FANTASIA/ThirdParty/whisper_cpp/scripts/
FANTASIA/ThirdParty/whisper_cpp/samples/
FANTASIA/ThirdParty/whisper_cpp/models/
FANTASIA/ThirdParty/whisper_cpp/grammars/
FANTASIA/ThirdParty/whisper_cpp/.github/
FANTASIA/ThirdParty/whisper_cpp/.devops/
FANTASIA/ThirdParty/whisper_cpp/ci/
FANTASIA/ThirdParty/whisper_cpp/.dockerignore
FANTASIA/ThirdParty/whisper_cpp/.gitignore
FANTASIA/ThirdParty/whisper_cpp/AUTHORS
FANTASIA/ThirdParty/whisper_cpp/Makefile
FANTASIA/ThirdParty/whisper_cpp/README.md
FANTASIA/ThirdParty/whisper_cpp/README_sycl.md
FANTASIA/ThirdParty/whisper_cpp/build-xcframework.sh
FANTASIA/ThirdParty/whisper_cpp/close-issue.yml

